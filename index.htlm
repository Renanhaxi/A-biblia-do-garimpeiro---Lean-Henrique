                </div>
                <div class="bg-bg-card p-6 rounded-xl border border-border-dark hover:border-accent/50 transition-colors shadow-lg">
                    <h3 class="font-bold text-text-main text-lg flex items-center">
                        <svg class="w-6 h-6 mr-3 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
