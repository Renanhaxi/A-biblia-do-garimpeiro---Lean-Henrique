    <!-- ÁREA DE OFERTA / VALOR COM GATILHO DE TIMING LOGÍSTICO -->
    <section id="offer" class="bg-bg-deep py-16 md:py-24 border-b border-border-dark">
        <div class="container mx-auto max-w-6xl px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
             <div class="order-1 md:order-1 flex justify-center px-4">
                <img src="https://i.postimg.cc/C5KMyFZv/capa-pare-de-procrastinar-3-em-1.png" alt="Enciclopédia do Garimpeiro" class="w-full max-w-sm md:max-w-full h-auto object-contain rounded-lg shadow-2xl shadow-accent/20">
            </div>
            
            <div class="text-center md:text-left order-2 md:order-2">
                <div class="mb-6">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-text-main">Acesso Exclusivo à <span class="text-accent">Enciclopédia Real</span></h2>
                </div>

                <div class="my-6 bg-bg-card p-6 md:p-8 rounded-2xl border border-accent/30 shadow-[0_0_20px_rgba(212,175,55,0.15)]">
                    <p class="text-lg text-text-main mb-4 font-semibold">O bônus de suporte prático para preenchimento de e-Visa expira em:</p>
                    
                    <div id="countdown" class="flex justify-center md:justify-start items-center gap-x-3 mb-6">
                        <div class="bg-bg-deep border border-border-dark p-3 rounded-lg w-20 text-center">
                            <span id="hours" class="text-3xl md:text-4xl font-bold text-accent block">00</span>
                            <span class="text-[10px] text-text-muted uppercase tracking-wider mt-1 block">Horas</span>
                        </div>
                        <span class="text-2xl font-bold text-accent">:</span>
                        <div class="bg-bg-deep border border-border-dark p-3 rounded-lg w-20 text-center">
                            <span id="minutes" class="text-3xl md:text-4xl font-bold text-accent block">00</span>
                            <span class="text-[10px] text-text-muted uppercase tracking-wider mt-1 block">Minutos</span>
                        </div>
                        <span class="text-2xl font-bold text-accent">:</span>
                        <div class="bg-bg-deep border border-border-dark p-3 rounded-lg w-20 text-center">
                            <span id="seconds" class="text-3xl md:text-4xl font-bold text-accent block">00</span>
                            <span class="text-[10px] text-text-muted uppercase tracking-wider mt-1 block">Segundos</span>
                        </div>
                    </div>
                    
                    <div class="border-t border-border-dark pt-6 text-center md:text-left">
                         <p class="text-xl line-through text-text-muted opacity-70">De R$ 197,00</p>
                        <div class="mt-1">
                            <p class="text-lg text-text-main mb-1">Por Apenas</p>
                            <!-- Henrique altera o preço aqui conforme a estratégia dele na Hotmart -->
                            <p class="text-5xl md:text-6xl font-black text-accent tracking-tight">R$ 67,00</p>
                            <p class="text-sm text-text-muted mt-2">Acesso imediato e vitalício ao material</p>
                        </div>
                    </div>
                </div>
                
                 <div class="mt-8 text-center md:text-left">
                    <!-- Lembrar Henrique de atualizar o link de checkout da Hotmart dele aqui -->
                    <a href="https://go.hotmart.com/L105909335F" target="_blank" rel="noopener noreferrer" class="block w-full sm:w-auto sm:inline-block bg-accent text-bg-deep font-bold text-xl md:text-2xl py-5 px-8 rounded-lg shadow-[0_0_20px_rgba(212,175,55,0.3)] hover:bg-accent-hover hover:-translate-y-1 transition-all duration-300 uppercase" onclick="fbq('track', 'InitiateCheckout');">
                        Baixar Manual e Blindar Meu Trecho
                    </a>
                 </div>
            </div>
        </div>
    </section>

    <!-- GARANTIA LEGAL -->
    <section class="bg-bg-alt py-16 border-b border-border-dark">
        <div class="container mx-auto max-w-4xl px-6 text-center flex flex-col md:flex-row items-center gap-8">
            <img src="https://img.icons8.com/plasticine/100/000000/guarantee.png" alt="Garantia" class="w-28 h-28 md:w-32 md:h-32 drop-shadow-[0_0_15px_rgba(212,175,55,0.3)] flex-shrink-0">
            <div class="text-left">
                 <h2 class="text-2xl md:text-3xl font-bold mb-4 text-text-main">Garantia Incondicional de 7 Dias</h2>
                <p class="text-text-muted text-base md:text-lg">Leia o material, analise as tabelas logísticas e as especificações técnicas da mochila de aço. Se em até 7 dias você entender que a realidade do trecho e as informações não servem para o seu plano, solicite o reembolso diretamente na plataforma. 100% do seu dinheiro de volta.</p>
            </div>
        </div>
    </section>

    <!-- BIOGRAFIA DO AUTOR BRUTALMENTE CONECTADA (CAPÍTULO 1 DO LIVRO) -->
    <section class="bg-bg-deep py-16 md:py-24 border-b border-border-dark">
        <div class="container mx-auto max-w-3xl px-6 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-accent mb-6">Quem É Henrique Galvão?</h2>
            <p class="text-base md:text-lg text-text-muted leading-relaxed text-left">
                Pai de 3 filhos, desembarquei no Suriname aos 24 anos sem nenhuma experiência em florestas tropicais profundas. Senti na pele o peso do garimpo manual na pá e na picareta. Fiquei isolado na mata, passei fome e fui forçado a caçar cobras e mucuras para sobreviver. Conheci o brefo das vacas magras, fui enganado por patrão abusivo, mas resisti e limpei uma porcentagem líquida única de 54 gramas de ouro purificado em maquinários mecanizados. Escrevi este livro para abrir os olhos dos trabalhadores e entregar o mapa exato que me fez voltar vivo e com a missão cumprida para casa.
            </p>
        </div>
    </section>
    
    <!-- FAQ ESPECÍFICO LOGÍSTICO -->
    <section class="bg-bg-alt py-16 md:py-20">
        <div class="container mx-auto max-w-3xl px-6">
            <h2 class="text-3xl font-bold text-center text-text-main mb-10">Perguntas Frequentes</h2>
            <div class="space-y-4">
                <details class="p-5 bg-bg-card border border-border-dark rounded-xl group cursor-pointer transition-all hover:border-accent/40">
                    <summary class="font-semibold text-text-main flex justify-between items-center outline-none list-none">
                        <span>Como funciona o suporte para preenchimento do e-Visa?</span>
                        <span class="text-accent group-open:rotate-180 transition-transform">▼</span>
                    </summary>
                    <p class="mt-4 text-text-muted text-sm md:text-base leading-relaxed">Nas páginas internas do livro você terá o link do canal oficial do suporte de compradores. Nossa equipe orienta você na emissão digital das taxas do governo para evitar vistos negados no embarque.</p>
                </details>
                
                <details class="p-5 bg-bg-card border border-border-dark rounded-xl group cursor-pointer transition-all hover:border-accent/40">
                    <summary class="font-semibold text-text-main flex justify-between items-center outline-none list-none">
                        <span>Preciso de quanto dinheiro líquido para aplicar a rota descrita?</span>
                        <span class="text-accent group-open:rotate-180 transition-transform">▼</span>
                    </summary>
                    <p class="mt-4 text-text-muted text-sm md:text-base leading-relaxed">Conforme detalhado no Capítulo 6, o recomendado é um capital de segurança mínimo de R$ 5.000,00 livres para cobrir deslocamento inicial, hotéis estratégicos em Paramaribo e fretes para grotas profundas.</p>
                </details>
                 
                 <details class="p-5 bg-bg-card border border-border-dark rounded-xl group cursor-pointer transition-all hover:border-accent/40">
                    <summary class="font-semibold text-text-main flex justify-between items-center outline-none list-none">
                        <span>O livro é físico ou digital? Como recebo?</span>
                        <span class="text-accent group-open:rotate-180 transition-transform">▼</span>
                    </summary>
                    <p class="mt-4 text-text-muted text-sm md:text-base leading-relaxed">O material é um livro digital (e-book) em formato PDF de alta resolução. O envio do arquivo e dos acessos aos bônus ocorre instantaneamente por e-mail após a aprovação da compra pela Hotmart.</p>
                </details>
            </div>
        </div>
    </section>

    <footer class="bg-bg-deep text-text-muted border-t border-border-dark">
        <div class="container mx-auto max-w-5xl px-6 py-8 text-center text-sm">
            <p>© 2026 - A Enciclopédia Real do Trecho - Todos os direitos reservados.</p>
            <p class="mt-2 opacity-60">Este produto não possui vínculo oficial com órgãos governamentais do Suriname e baseia-se em experiências profissionais em mineração autônoma.</p>
        </div>
    </footer>
    
    <script>
        function startCountdown() {
            const countdownEl = {
                hours: document.getElementById('hours'),
                minutes: document.getElementById('minutes'),
                seconds: document.getElementById('seconds'),
            };

            if (!countdownEl.hours) return;

            const duration = 60 * 60 * 1000; 
            let endTime = localStorage.getItem('countdownEndTimeGarimpo');

            if (!endTime || new Date().getTime() > parseInt(endTime)) {
                endTime = new Date().getTime() + duration;
                localStorage.setItem('countdownEndTimeGarimpo', endTime);
            }

            const countDownDate = parseInt(endTime);

            const interval = setInterval(() => {
                const now = new Date().getTime();
                const distance = countDownDate - now;

                if (distance < 0) {
                    clearInterval(interval);
                    localStorage.removeItem('countdownEndTimeGarimpo');
                    document.getElementById("countdown").innerHTML = "<div class='text-xl font-bold text-accent'>BÔNUS EXPIRADO</div>";
                    return;
                }
                
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                
                countdownEl.hours.textContent = hours.toString().padStart(2, '0');
                countdownEl.minutes.textContent = minutes.toString().padStart(2, '0');
                countdownEl.seconds.textContent = seconds.toString().padStart(2, '0');

            }, 1000);
        }
        
        startCountdown();
    </script>
</body>
</html>
